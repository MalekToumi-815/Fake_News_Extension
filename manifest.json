{
    "manifest_version": 3,
    "name": "Fake News AI",
    "version": "1.0",
    "permissions": ["activeTab", "scripting", "tabCapture"],
    "host_permissions": ["<all_urls>"],
    "action": {
        "default_popup": "popup/popup.html"
    },
    "background": {
        "service_worker": "scripts/background.js"
    }
}